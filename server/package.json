{
  "name": "indparkdocs-server",
  "version": "1.0.0",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "db:migrate": "node src/migrations/001_initial.js && node src/migrations/002_auth_audit.js",
    "db:seed": "node src/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "syntax": "find src -name '*.js' -not -name '*.min.js' -exec node --check {} +"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^13.3.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testTimeout": 15000,
    "moduleNameMapper": {
      "^otplib$": "<rootDir>/tests/__mocks__/otplib.js"
    }
  }
}
